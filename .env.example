# ShopSteward — environment configuration
# Copy to .env and fill in. NEVER commit .env. See docs/setup/ for how to
# obtain each credential.

# --- Etsy (Open API v3, OAuth 2.0) ---------------------------------------
# Register a personal app at https://www.etsy.com/developers/
ETSY_API_KEY=
ETSY_SHARED_SECRET=
ETSY_SHOP_ID=
# Populated by `shopsteward auth etsy` after the OAuth dance:
ETSY_REFRESH_TOKEN=

# --- Printful --------------------------------------------------------------
# Private token from https://developers.printful.com/ (scoped to your store)
PRINTFUL_API_TOKEN=
PRINTFUL_STORE_ID=

# --- Gelato ----------------------------------------------------------------
# API key from the Gelato dashboard (Developer section)
GELATO_API_KEY=
GELATO_STORE_ID=

# --- Instagram (Graph API, Business account) --------------------------------
IG_APP_ID=
IG_APP_SECRET=
IG_BUSINESS_ACCOUNT_ID=
IG_LONG_LIVED_TOKEN=

# --- AI adapters -------------------------------------------------------------
# Vision scoring (commercial viability):
ANTHROPIC_API_KEY=
# Scene generation — configure at least one:
GOOGLE_AI_API_KEY=
REPLICATE_API_TOKEN=

# --- Paths -------------------------------------------------------------------
# Lightroom candidate export folder ShopSteward watches (Stage 1):
LR_CANDIDATE_EXPORT_DIR=
# Staging folder for finished hero exports (Gate 2 approval signal):
LR_STAGING_DIR=
# Jobs folder polled by the EPD Edit Bridge plugin:
EPD_JOBS_DIR=

# --- Budgets -------------------------------------------------------------------
# Monthly cap in USD for scene generation + vision scoring combined:
AI_MONTHLY_BUDGET_USD=25
